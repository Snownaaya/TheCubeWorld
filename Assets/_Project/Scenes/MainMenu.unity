  text: "\u041D\u0430\u0447\u0430\u043B\u043E:  \u041F\u0440\u043E\u0439\u0434\u0438\u0442\u0435
    \u043F\u0435\u0440\u0432\u044B\u0439 \u0443\u0440\u043E\u0432\u0435\u043D."
  ru: "\u042D\u0441\u0442\u0435\u0442:\n\u041F\u0440\u043E\u0439\u0434\u0438\u0442\u0435
    \u0432\u0435\u0441\u044C \u0443\u0440\u043E\u0432\u0435\u043D\u044C \u0441\u0442\u0440\u043E\u044F
    \u0442\u043E\u043B\u044C\u043A\u043E \u0434\u0435\u0440\u0435\u0432\u044F\u043D\u043D\u044B\u0435
    \u043C\u043E\u0441\u0442\u044B, \u0432\u044B\u0441\u043E\u043A\u043E\u0439 \u0441\u043B\u043E\u0436\u043D\u043E\u0441\u0442\u0438."
